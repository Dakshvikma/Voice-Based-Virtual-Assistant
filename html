<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ecosystem Guardian Chatbot</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            --chat-bg: #f9fafb; /* gray-50 */
            --user-bubble: #dbeafe; /* blue-200 */
            --bot-bubble: #e5e7eb; /* gray-200 */
            --text-dark: #1f2937; /* gray-800 */
            --text-light: #4b5563; /* gray-600 */
        }
        .dark body {
            --chat-bg: #111827; /* gray-900 */
            --user-bubble: #1e40af; /* blue-800 */
            --bot-bubble: #374151; /* gray-700 */
            --text-dark: #f9fafb; /* gray-50 */
            --text-light: #d1d5db; /* gray-300 */
        }
        #chat-container {
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
        .chat-message {
            opacity: 0;
            transform: translateY(20px);
            animation: fadeIn 0.5s ease-out forwards;
        }
        @keyframes fadeIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        .dot-flashing {
            position: relative;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background-color: #9880ff;
            color: #9880ff;
            animation: dotFlashing 1s infinite linear alternate;
            animation-delay: .5s;
        }
        .dot-flashing::before, .dot-flashing::after {
            content: '';
            display: inline-block;
            position: absolute;
            top: 0;
        }
        .dot-flashing::before {
            left: -15px;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background-color: #9880ff;
            color: #9880ff;
            animation: dotFlashing 1s infinite alternate;
            animation-delay: 0s;
        }
        .dot-flashing::after {
            left: 15px;
            width: 10px;
            height: 10px;
            border-radius: 5px;
            background-color: #9880ff;
            color: #9880ff;
            animation: dotFlashing 1s infinite alternate;
            animation-delay: 1s;
        }

        @keyframes dotFlashing {
            0% {
                background-color: #A3A3A3;
            }
            50%,
            100% {
                background-color: #64748B;
            }
        }
    </style>
</head>
<body class="bg-gray-100 dark:bg-gray-900 transition-colors duration-300">

    <div id="chat-container" class="flex flex-col h-screen max-w-2xl mx-auto bg-white dark:bg-gray-800 rounded-lg overflow-hidden my-0 sm:my-4">
        <!-- Header -->
        <header class="bg-emerald-600 dark:bg-emerald-800 text-white p-4 flex items-center justify-between shadow-md">
            <div>
                <h1 class="text-xl font-bold">Ecosystem Guardian</h1>
                <p class="text-sm opacity-90">Your guide to our restoration project</p>
            </div>
             <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-leaf"><path d="M11 20A7 7 0 0 1 4 13V8a5 5 0 0 1 10 0v5a7 7 0 0 1-7 7Z"/><path d="M20.34 11.66A5 5 0 0 0 13 8V3a1 1 0 0 0-2 0v5a5 5 0 0 0 7 4.66Z"/></svg>
        </header>

        <!-- Messages -->
        <main id="messages" class="flex-1 p-6 overflow-y-auto bg-gray-50 dark:bg-gray-900/50 space-y-4">
            <!-- Initial Bot Message -->
            <div class="chat-message flex">
                <div class="bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-gray-200 rounded-lg p-3 max-w-xs">
                    <p>Hello! I'm the Ecosystem Guardian assistant. I can answer questions about our project based on the Lean Canvas and presentation. How can I help you?</p>
                </div>
            </div>
            <!-- Chat messages will be appended here -->
        </main>

        <!-- Loading Indicator -->
        <div id="loading-indicator" class="hidden p-6 pt-0">
            <div class="flex">
                 <div class="bg-gray-200 dark:bg-gray-700 rounded-lg p-4 max-w-xs">
                    <div class="dot-flashing"></div>
                </div>
            </div>
        </div>


        <!-- Input Form -->
        <footer class="p-4 bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
            <form id="chat-form" class="flex items-center space-x-3">
                <input type="text" id="user-input" placeholder="Ask about the project..." class="flex-1 p-3 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-emerald-500 focus:outline-none bg-gray-50 dark:bg-gray-700 text-gray-800 dark:text-gray-200">
                <button type="submit" class="bg-emerald-600 text-white p-3 rounded-lg hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-emerald-500 disabled:bg-emerald-400 dark:disabled:bg-emerald-800 disabled:cursor-not-allowed transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
                </button>
            </form>
        </footer>
    </div>

    <script>
        const chatForm = document.getElementById('chat-form');
        const userInput = document.getElementById('user-input');
        const messagesContainer = document.getElementById('messages');
        const loadingIndicator = document.getElementById('loading-indicator');
        const sendButton = chatForm.querySelector('button');

        // Main logic for handling chat
        chatForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const userMessage = userInput.value.trim();
            if (!userMessage) return;

            addMessage(userMessage, 'user');
            userInput.value = '';
            sendButton.disabled = true;
            loadingIndicator.classList.remove('hidden');
            messagesContainer.scrollTop = messagesContainer.scrollHeight;

            try {
                const botResponse = await getBotResponse(userMessage);
                addMessage(botResponse, 'bot');
            } catch (error) {
                console.error("Error fetching bot response:", error);
                addMessage("Sorry, I encountered an error. Please try again.", 'bot');
            } finally {
                loadingIndicator.classList.add('hidden');
                sendButton.disabled = false;
                userInput.focus();
            }
        });

        // Appends a message to the chat window
        function addMessage(text, sender) {
            const messageWrapper = document.createElement('div');
            messageWrapper.classList.add('chat-message', 'flex');

            const messageBubble = document.createElement('div');
            messageBubble.classList.add('rounded-lg', 'p-3', 'max-w-md');

            if (sender === 'user') {
                messageWrapper.classList.add('justify-end');
                messageBubble.classList.add('bg-blue-500', 'text-white');
            } else {
                messageWrapper.classList.add('justify-start');
                messageBubble.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-800', 'dark:text-gray-200');
            }

            messageBubble.innerHTML = `<p>${text.replace(/\n/g, '<br>')}</p>`; // Basic Markdown support for newlines
            messageWrapper.appendChild(messageBubble);
            messagesContainer.appendChild(messageWrapper);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        // --- Gemini API Call ---
        async function getBotResponse(userMessage) {
            // IMPORTANT: In a real application, you should never expose the API key in the client-side code.
            // This should be handled by a backend server. For this example, we leave it as an empty string
            // and assume the environment provides it.
            const apiKey = "";
            const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-05-20:generateContent?key=${apiKey}`;

            // This system prompt is created by synthesizing the provided PDF and PPTX content.
            // It instructs the model on how to behave and what its knowledge base is.
            const systemPrompt = `
                You are "Ecosystem Guardian," a helpful AI assistant. Your purpose is to provide information about the "Sustainable Ecosystem Guardian" and "TerraForm" project. Your knowledge comes exclusively from the following information synthesized from a Lean Canvas document and a presentation. Do not use any external knowledge. If a question cannot be answered from the text below, politely state that you don't have that information.

                **Project Overview:**
                The project is a technology platform named TerraForm (also referred to as Ecosystem Guardian) designed to make ecological restoration profitable and scalable. It connects landowners with financing and expertise to turn degraded land into thriving ecosystems. The high-level concept is a marketplace and management platform for Earth restoration.

                **Problem It Solves:**
                - Landowners (farmers, communities) lack the specialized knowledge, resources, and financial incentives for ecological restoration.
                - Corporations and governments need access to verifiable, high-impact restoration projects for their climate and ESG goals.
                - There's a disconnect between available conservation funding and projects that need it.
                - Monitoring and verifying the long-term success of restoration is complex and expensive.

                **Solution Provided:**
                A web and mobile platform offering:
                1.  **Project Marketplace:** Connects landowners who need funding with corporations and investors.
                2.  **Restoration Planning Tools:** Uses satellite data and ecological models to design effective projects (e.g., reforestation, soil regeneration).
                3.  **AI-Powered Monitoring & Verification:** Employs AI analysis of satellite (Sentinel-2, Landsat-8, MODIS) and drone imagery to track progress and verify outcomes like carbon sequestration and biodiversity gains. This is a key "Unfair Advantage" as it's more trusted and cost-effective than traditional methods.
                4.  **Financial Gateway:** Facilitates transactions for carbon credits, biodiversity offsets, and other environmental assets.

                **Target Customers/Segments:**
                - **Landowners:** Farmers, rural communities, corporations with land holdings.
                - **Funders:** Corporations with sustainability/net-zero goals, ESG investment funds, governments, philanthropic foundations.
                - **Service Providers:** Ecologists, restoration companies, and local NGOs.

                **Key Metrics for Success:**
                - Hectares under active restoration.
                - Total capital deployed.
                - Verified tons of CO2 sequestered.
                - Number of active projects and users.

                **Technology Stack:**
                - **Cloud Platforms:** Google Earth Engine, AWS.
                - **Languages/Libraries:** Python, TensorFlow, OpenCV, GeoPandas.
                - **Deployment:** REST API for integration, a dashboard for visualization, and mobile alerts for field officers.

                **Revenue Streams:**
                1.  **Transaction Fee:** 5-10% of total project funding.
                2.  **Monitoring Subscription (SaaS):** Recurring fee for premium monitoring and reporting services.
                3.  **Data & Analytics:** Selling aggregated, anonymized data to policymakers and researchers.

                Keep your answers friendly, concise, and directly based on this information.
            `;

            const payload = {
                contents: [{
                    parts: [{ text: userMessage }]
                }],
                tools: [{
                    "google_search": {} // Enables grounding, though the prompt restricts its use.
                }],
                systemInstruction: {
                    parts: [{ text: systemPrompt }]
                },
            };

            // Exponential backoff for retries
            let response;
            let retries = 3;
            let delay = 1000;
            while (retries > 0) {
                try {
                    response = await fetch(apiUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload)
                    });
                    if (response.ok) {
                        const result = await response.json();
                        const candidate = result.candidates?.[0];
                        if (candidate && candidate.content?.parts?.[0]?.text) {
                            return candidate.content.parts[0].text;
                        } else {
                           throw new Error("Invalid response structure from API.");
                        }
                    } else if (response.status === 429 || response.status >= 500) {
                        // Throttling or server error, so retry
                        throw new Error(`API request failed with status ${response.status}`);
                    } else {
                        // Other client-side error, don't retry
                        const errorResult = await response.json();
                        console.error("API Error:", errorResult);
                        return `I'm sorry, but I encountered an issue: ${errorResult.error?.message || 'Unknown error'}`;
                    }
                } catch (error) {
                    console.warn(`API request failed, retrying in ${delay / 1000}s...`, error);
                    retries--;
                    if (retries === 0) {
                        return "I'm having trouble connecting to my knowledge base right now. Please try again later.";
                    }
                    await new Promise(res => setTimeout(res, delay));
                    delay *= 2; // Double the delay for the next retry
                }
            }
        }
    </script>
</body>
</html>
